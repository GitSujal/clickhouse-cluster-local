# Environment and credentials (NEVER commit these!)
.env
.credentials

# Generated configuration files (regenerated by setup.sh)
# These contain environment-specific values and should not be in git
prometheus.yml
haproxy-http.cfg
haproxy-https.cfg
fs/
grafana/provisioning/
.claude/

# TLS certificates (NEVER commit private keys!)
certs/
*.pem
*.key
*.crt
*.csr

# Docker volumes are managed by Docker, not git
# (Data persistence is handled by named volumes in docker-compose.yml)

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Backup files
*.tar.gz
backups/

# Logs
*.log

# Temporary files
*.tmp
.cache/
