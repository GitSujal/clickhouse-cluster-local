# ClickHouse Cluster Environment Variables
#
# IMPORTANT: Do not use this file directly!
#
# Option 1 (Recommended): Run ./generate-env.sh to interactively create .env with secure passwords
# Option 2 (Manual): Copy this file to .env and replace all <PLACEHOLDER> values
#
# To generate SHA256 hashes for ClickHouse passwords:
#   echo -n "your_password" | sha256sum | awk '{print $1}'
#

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<GF_SECURITY_ADMIN_PASSWORD>
GF_SECURITY_SECRET_KEY=<GF_SECURITY_SECRET_KEY>

# ClickHouse Passwords (must be SHA256 hashes, not plain text!)
CLICKHOUSE_ADMIN_PASSWORD_SHA256=<ADMIN_PASSWORD_SHA256>
CLICKHOUSE_APP_USER_PASSWORD_SHA256=<APP_USER_PASSWORD_SHA256>

# HAProxy Stats Authentication
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=<HAPROXY_STATS_PASSWORD>